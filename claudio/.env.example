# ===== QQ 音乐 =====
# 本地 QQMusicApi 服务地址（jsososo/QQMusicApi）
QQMUSIC_API_URL=http://127.0.0.1:3300
# 你的 QQ 号（不带 o 前缀）
# 留空或保持占位的话，npm start 时会交互式问你
QQ_UIN=

# ===== 大脑（CodeBuddy / Claude Code）=====
# 推荐用 npm run setup:brain 交互式选择，会自动写这两行
BRAIN_BIN=codebuddy            # 实际可执行命令: codebuddy / claude / 绝对路径
BRAIN_FLAVOR=codebuddy         # 仅做日志/UI 显示: codebuddy / claude / claude-internal

# 兼容老变量（如果你有老 .env，下面这行也认）
# CODEBUDDY_BIN=codebuddy

# ===== 服务端口 =====
PORT=8080

# ===== 可选 · 天气（推荐打开） =====
# 1. https://dev.qweather.com/ 注册
# 2. 控制台 → 应用管理 → 创建应用（凭据类型选 API KEY）拿 KEY
# 3. 控制台 → 设置 → API Host（专属域名，如 xxx.re.qweatherapi.com）
# 4. 控制台 → 数据服务 → 城市信息查询，搜你的城市拿 LocationID
ENABLE_WEATHER=false
QWEATHER_KEY=
QWEATHER_HOST=
QWEATHER_LOCATION=101280601

# ===== 可选 · 语音 =====
ENABLE_TTS=false
FISH_API_KEY=
FISH_VOICE_ID=

# ===== 行为 =====
PORT=8080
SCHEDULE_ENABLED=true
SONGS_PER_BLOCK=5

# ===== 数据目录（默认与 claudio 同级的 ../data）=====
# CLAUDIO_DATA_DIR=/absolute/path/to/data
